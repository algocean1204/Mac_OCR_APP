{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OCR Progress Message",
  "description": "Python 백엔드 -> Flutter 프론트엔드 stdout 메시지 스키마",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "type": { "const": "init" },
        "model_name": { "type": "string" },
        "model_loaded": { "type": "boolean" },
        "total_pages": { "type": "integer", "minimum": 1 },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "model_name", "model_loaded", "total_pages", "timestamp"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "type": { "const": "progress" },
        "current_page": { "type": "integer", "minimum": 1 },
        "total_pages": { "type": "integer", "minimum": 1 },
        "percent": { "type": "number", "minimum": 0, "maximum": 100 },
        "status": {
          "type": "string",
          "enum": ["extracting_image", "ocr_processing", "writing_output", "page_complete"]
        },
        "memory_mb": { "type": "integer", "minimum": 0 },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "current_page", "total_pages", "percent", "status", "timestamp"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "type": { "const": "download" },
        "downloaded_mb": { "type": "number", "minimum": 0 },
        "total_mb": { "type": "number", "minimum": 0 },
        "percent": { "type": "number", "minimum": 0, "maximum": 100 },
        "status": {
          "type": "string",
          "enum": ["downloading", "verifying", "extracting"]
        },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "downloaded_mb", "total_mb", "percent", "status", "timestamp"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "type": { "const": "complete" },
        "output_path": { "type": "string" },
        "total_pages": { "type": "integer", "minimum": 1 },
        "elapsed_seconds": { "type": "number", "minimum": 0 },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "output_path", "total_pages", "elapsed_seconds", "timestamp"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "type": { "const": "log" },
        "level": {
          "type": "string",
          "enum": ["debug", "info", "warn"]
        },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "level", "message", "timestamp"],
      "additionalProperties": false
    }
  ]
}
